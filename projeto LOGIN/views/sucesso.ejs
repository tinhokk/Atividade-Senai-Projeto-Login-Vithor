<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <title>Cadastro realizado</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .card {

            background: white;
            padding: 40px;
            width: 450px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 0, 0, .2);
            text-align: center;

        }

        h1 {

            color: #28a745;

        }

        a {

            display: inline-block;
            margin-top: 25px;
            padding: 12px 30px;
            background: #0d6efd;
            color: white;
            text-decoration: none;
            border-radius: 8px;

        }

        a:hover {

            background: #0b5ed7;

        }
    </style>

</head>

<body>

    <div class="card">

        <h1>Cadastro realizado!</h1>

        <p>

            Parabéns <b>
                <%= nome %>
            </b>.

        </p>

        <p>

            Seu cadastro foi realizado com sucesso.

        </p>

        <a href="/login">

            Ir para tela de Login

        </a>

    </div>

</body>

</html>